{
  "name": "braneiq-web",
  "version": "0.1.0",
  "private": true,
  "description": "BraneIQ Website - Deployed on EC2",
  "scripts": {
    "dev": "pnpm --filter @braneiq/web dev",
    "build": "pnpm --filter @braneiq/shared-types build && pnpm --filter @braneiq/web build",
    "start": "pnpm --filter @braneiq/web start",
    "lint": "pnpm --filter @braneiq/web lint"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
