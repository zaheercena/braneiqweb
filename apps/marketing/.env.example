# ─── SMTP Configuration ───────────────────────────────────────────────────────
# Required for the /api/contact route to send demo request emails to support@braneiq.com
# Copy this file to .env.local and fill in your SMTP credentials.

# Your SMTP server hostname (e.g. smtp.gmail.com, smtp.sendgrid.net, mail.braneiq.com)
SMTP_HOST=smtp.example.com

# SMTP port: 587 for STARTTLS (recommended), 465 for SSL, 25 for plain
SMTP_PORT=587

# SMTP login username (usually your full email address)
SMTP_USER=support@braneiq.com

# SMTP login password or app-specific password
SMTP_PASS=your-smtp-password-here

# ─── Optional: override the destination address ───────────────────────────────
# If not set, emails are always sent to support@braneiq.com (hardcoded in route.ts)
# CONTACT_TO=support@braneiq.com
